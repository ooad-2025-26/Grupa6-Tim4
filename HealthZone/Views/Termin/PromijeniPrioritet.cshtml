@model HealthZone.Models.Korisnik

@{
    ViewData["Title"] = "Promijeni prioritet";
    var trenutniPrioritet = Model?.Prioritet?.ToString() ?? "";
    var isNizak = trenutniPrioritet == "Nizak";
    var isSrednji = trenutniPrioritet == "Srednji";
    var isVisok = trenutniPrioritet == "Visok";

    var prioritetBadge = trenutniPrioritet switch
    {
        "Nizak" => "hz-badge hz-badge-success",
        "Srednji" => "hz-badge hz-badge-warning",
        "Visok" => "hz-badge hz-badge-danger",
        _ => "hz-badge hz-badge-info"
    };
    var prioritetLabel = string.IsNullOrEmpty(trenutniPrioritet) ? "Nije postavljen" : trenutniPrioritet;
}

<link rel="stylesheet" href="~/css/healthzone.css" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

<div class="hz-page hz-page-narrow">
    <a href="javascript:history.back()" class="hz-back">Nazad</a>

    <div class="hz-header">
        <div class="hz-logo">🎯</div>
        <div class="hz-header-main">
            <h1 class="hz-title">Promijeni prioritet</h1>
            <p class="hz-subtitle">Postavite prioritet pacijentu na listi čekanja.</p>
        </div>
    </div>

    <div class="hz-card">
        <div class="hz-section-title">Pacijent</div>

        <div class="hz-grid">
            <div class="hz-field">
                <label class="hz-label">Ime i prezime</label>
                <div class="hz-input hz-readonly">@ViewBag.PacijentIme</div>
            </div>
            <div class="hz-field">
                <label class="hz-label">Email</label>
                <div class="hz-input hz-readonly">@Model?.Email</div>
            </div>
            <div class="hz-field">
                <label class="hz-label">Trenutni prioritet</label>
                <div class="hz-input hz-readonly">
                    <span class="@prioritetBadge">@prioritetLabel</span>
                </div>
            </div>
        </div>

        <form method="post" asp-action="PromijeniPrioritet">
            <input type="hidden" name="pacijentId" value="@Model?.Id" />

            <div class="hz-section-title" style="margin-top:24px">Novi prioritet</div>

            <div class="hz-grid">
                <div class="hz-field hz-full">
                    <label class="hz-label">Odaberite prioritet<span class="req">*</span></label>
                    <select name="prioritet" id="prioritet" class="hz-select">
                        <option value="">-- Bez prioriteta --</option>
                        @if (isNizak)
                        {
                            <option value="Nizak" selected>🟢 Nizak</option>
                        }
                        else
                        {
                            <option value="Nizak">🟢 Nizak</option>
                        }
                        @if (isSrednji)
                        {
                            <option value="Srednji" selected>🟡 Srednji</option>
                        }
                        else
                        {
                            <option value="Srednji">🟡 Srednji</option>
                        }
                        @if (isVisok)
                        {
                            <option value="Visok" selected>🔴 Visok</option>
                        }
                        else
                        {
                            <option value="Visok">🔴 Visok</option>
                        }
                    </select>
                </div>

                <div class="hz-field hz-full">
                    <div class="hz-notice">
                        <p><strong>📌 Šta znači koji prioritet?</strong></p>
                        <p>🟢 <strong>Nizak</strong> — rutinski pregledi, nema žurbe</p>
                        <p>🟡 <strong>Srednji</strong> — potrebna pažnja, ali nije hitno</p>
                        <p>🔴 <strong>Visok</strong> — hitan slučaj, prioritetno zakazivanje</p>
                        <p style="margin-top:8px;color:var(--hz-accent)">※ Pacijenti sa višim prioritetom prikazuju se na vrhu liste čekanja.</p>
                    </div>
                </div>
            </div>

            <div class="hz-actions">
                <a asp-action="MojiPacijenti" class="hz-btn hz-btn-ghost">Odustani</a>
                <button type="submit" class="hz-btn hz-btn-primary">💾 Sačuvaj promjene</button>
            </div>
        </form>
    </div>
</div>
