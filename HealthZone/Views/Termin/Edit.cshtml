@model HealthZone.Models.Termin

@{
    ViewData["Title"] = "Uredi termin";
    var doktorItems = ViewData["DoktorID"] as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var pacijentItems = ViewData["PacijentID"] as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var uslugaItems = ViewData["UslugaID"] as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
}

<link rel="stylesheet" href="~/css/healthzone.css" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

<div class="hz-page hz-page-narrow">
    <a href="javascript:history.back()" class="hz-back">Nazad</a>

    <div class="hz-header">
        <div class="hz-logo">📅</div>
        <div class="hz-header-main">
            <h1 class="hz-title">Uredi termin</h1>
            <p class="hz-subtitle">Ažurirajte podatke postojeće stavke u HealthZone sistemu.</p>
        </div>
    </div>

    <div class="hz-card">
        <form asp-action="Edit" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
            <input type="hidden" asp-for="TerminId" />
            <div class="hz-section-title">Podaci</div>

            <div class="hz-grid">
                <div class="hz-field">
                    <label asp-for="Datum" class="hz-label">Datum<span class="req">*</span></label>
                    <input type="date" asp-for="Datum" class="hz-input" />
                    <span asp-validation-for="Datum" class="hz-error"></span>
                </div>
                <div class="hz-field">
                    <label asp-for="Vrijeme" class="hz-label">Vrijeme<span class="req">*</span></label>
                    <input type="time" asp-for="Vrijeme" class="hz-input" />
                    <span asp-validation-for="Vrijeme" class="hz-error"></span>
                </div>
                <div class="hz-field">
                    <label asp-for="Status" class="hz-label">Status</label>
                    <select asp-for="Status" class="hz-select" asp-items="Html.GetEnumSelectList<HealthZone.Models.Status>()">
                        <option value="">— Odaberite —</option>
                    </select>
                    <span asp-validation-for="Status" class="hz-error"></span>
                </div>
                <div class="hz-field">
                    <label asp-for="DoktorID" class="hz-label">Doktor<span class="req">*</span></label>
                    <select asp-for="DoktorID" class="hz-select" asp-items="doktorItems">
                        <option value="">— Odaberite —</option>
                    </select>
                    <span asp-validation-for="DoktorID" class="hz-error"></span>
                </div>
                <div class="hz-field">
                    <label asp-for="PacijentID" class="hz-label">Pacijent<span class="req">*</span></label>
                    <select asp-for="PacijentID" class="hz-select" asp-items="pacijentItems">
                        <option value="">— Odaberite —</option>
                    </select>
                    <span asp-validation-for="PacijentID" class="hz-error"></span>
                </div>
                <div class="hz-field hz-full">
                    <label asp-for="UslugaID" class="hz-label">Usluga<span class="req">*</span></label>
                    <select asp-for="UslugaID" class="hz-select" asp-items="uslugaItems">
                        <option value="">— Odaberite —</option>
                    </select>
                    <span asp-validation-for="UslugaID" class="hz-error"></span>
                </div>
            </div>

            <div class="hz-actions">
                <a asp-action="Index" class="hz-btn hz-btn-ghost">Odustani</a>
                <button type="submit" class="hz-btn hz-btn-primary">Sačuvaj izmjene</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
