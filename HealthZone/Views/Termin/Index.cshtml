@model IEnumerable<HealthZone.Models.Termin>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Datum)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Vrijeme)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Status)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Doktor)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Pacijent)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Usluga)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Datum)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Vrijeme)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Status)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Doktor.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Pacijent.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Usluga.UslugaId)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.TerminId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.TerminId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.TerminId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
