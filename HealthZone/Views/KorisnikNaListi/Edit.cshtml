@model HealthZone.Models.KorisnikNaListi

@{
    ViewData["Title"] = "Uredi stavku na listi čekanja";
    var listaItems = ViewData["ListaID"] as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var korisnikItems = ViewData["KorisnikID"] as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
}

<link rel="stylesheet" href="~/css/healthzone.css" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

<div class="hz-page hz-page-narrow">
    <a href="javascript:history.back()" class="hz-back">Nazad</a>

    <div class="hz-header">
        <div class="hz-logo">🕐</div>
        <div class="hz-header-main">
            <h1 class="hz-title">Uredi stavku na listi čekanja</h1>
            <p class="hz-subtitle">Ažurirajte podatke o pacijentu na listi čekanja.</p>
        </div>
    </div>

    <div class="hz-card">
        <form asp-action="Edit" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
            <input type="hidden" asp-for="KorisnikNaListiID" />
            <div class="hz-section-title">Podaci</div>

            <div class="hz-grid">
                <div class="hz-field hz-full">
                    <label asp-for="ListaID" class="hz-label">Lista čekanja<span class="req">*</span></label>
                    <select asp-for="ListaID" class="hz-select" asp-items="listaItems">
                        <option value="">— Odaberite listu —</option>
                    </select>
                    <span asp-validation-for="ListaID" class="hz-error"></span>
                </div>
                <div class="hz-field hz-full">
                    <label asp-for="KorisnikID" class="hz-label">Pacijent<span class="req">*</span></label>
                    <select asp-for="KorisnikID" class="hz-select" asp-items="korisnikItems">
                        <option value="">— Odaberite pacijenta —</option>
                    </select>
                    <span asp-validation-for="KorisnikID" class="hz-error"></span>
                </div>
                <div class="hz-field hz-full">
                    <label asp-for="Datum" class="hz-label">Datum prijave</label>
                    <input type="datetime-local" asp-for="Datum" class="hz-input"
                           value="@Model.Datum.ToString("yyyy-MM-ddTHH:mm")" />
                    <span asp-validation-for="Datum" class="hz-error"></span>
                </div>
            </div>

            <div class="hz-actions">
                <a asp-action="Index" class="hz-btn hz-btn-ghost">Odustani</a>
                <button type="submit" class="hz-btn hz-btn-primary">Sačuvaj izmjene</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
