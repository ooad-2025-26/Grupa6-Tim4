@model HealthZone.Models.Nalaz
@using HealthZone.Models

@{
    ViewData["Title"] = "Detalji nalaza";
}

<link rel="stylesheet" href="~/css/healthzone.css" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

<div class="hz-page hz-page-narrow">
    <a href="javascript:history.back()" class="hz-back">Nazad</a>

    <div class="hz-header">
        <div class="hz-logo">📋</div>
        <div class="hz-header-main">
            <h1 class="hz-title">Detalji nalaza</h1>
            <p class="hz-subtitle">Pregled svih informacija za odabrani medicinski nalaz.</p>
        </div>
    </div>

    <div class="hz-card">
        <div class="hz-section-title">Podaci o pacijentu</div>
        <div class="hz-grid">
            <div class="hz-field">
                <label class="hz-label">Pacijent</label>
                <div class="hz-input hz-readonly">
                    @(Model.Pacijent != null ? $"{Model.Pacijent.Ime} {Model.Pacijent.Prezime}" : Model.PacijentID)
                </div>
            </div>
            <div class="hz-field">
                <label class="hz-label">Broj kartona</label>
                <div class="hz-input hz-readonly">
                    @(Model.Pacijent?.BrojKartona ?? "—")
                </div>
            </div>
            <div class="hz-field">
                <label class="hz-label">Datum pregleda</label>
                <div class="hz-input hz-readonly">
                    @(Model.Termin != null ? Model.Termin.Datum.ToString("dd.MM.yyyy") : "—")
                </div>
            </div>
            <div class="hz-field">
                <label class="hz-label">Vrijeme pregleda</label>
                <div class="hz-input hz-readonly">
                    @(Model.Termin != null ? Model.Termin.Vrijeme.ToString("HH:mm") : "—")
                </div>
            </div>
        </div>

        <div class="hz-section-title" style="margin-top:24px">Medicinski nalaz</div>
        <div class="hz-grid">
            <div class="hz-field hz-full">
                <label class="hz-label">Dijagnoza</label>
                <div class="hz-input hz-readonly">@Model.Dijagnoza</div>
            </div>
            <div class="hz-field hz-full">
                <label class="hz-label">Opis nalaza</label>
                <div class="hz-input hz-readonly" style="min-height:60px;white-space:pre-wrap">@Model.Opis</div>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.Terapija))
            {
                <div class="hz-field hz-full">
                    <label class="hz-label">Terapija</label>
                    <div class="hz-input hz-readonly" style="min-height:60px;white-space:pre-wrap">@Model.Terapija</div>
                </div>
            }
        </div>

        <div class="hz-actions hz-actions-between">
            <a asp-action="Index" class="hz-btn hz-btn-ghost">Nazad</a>
            <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
                @if (User.IsInRole("Doktor") || User.IsInRole("Administrator"))
                {
                    <a asp-action="Edit" asp-route-id="@Model.NalazId" class="hz-btn hz-btn-ghost">Uredi</a>
                    <a asp-action="Delete" asp-route-id="@Model.NalazId" class="hz-btn hz-btn-danger">Obriši</a>
                }
                @if (User.IsInRole("MedicinskaSestra") || User.IsInRole("Doktor") || User.IsInRole("Administrator"))
                {
                    <a asp-action="Print" asp-route-id="@Model.NalazId" class="hz-btn hz-btn-primary" target="_blank">🖨️ Odštampaj nalaz</a>
                }
            </div>
        </div>
    </div>
</div>
