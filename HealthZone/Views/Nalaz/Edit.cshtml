@model HealthZone.Models.Nalaz

@{
    ViewData["Title"] = "Uredi nalaz";
}

<link rel="stylesheet" href="~/css/healthzone.css" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

<div class="hz-page hz-page-narrow">
    <a href="javascript:history.back()" class="hz-back">Nazad</a>

    <div class="hz-header">
        <div class="hz-logo">📋</div>
        <div class="hz-header-main">
            <h1 class="hz-title">Uredi nalaz</h1>
            <p class="hz-subtitle">Ažurirajte podatke postojeće stavke u HealthZone sistemu.</p>
        </div>
    </div>

    <div class="hz-card">
        <form asp-action="Edit" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
            <input type="hidden" asp-for="NalazId" />
            <div class="hz-section-title">Podaci</div>

            <div class="hz-grid">
        <div class="hz-field">
            <label asp-for="TerminID" class="hz-label">Termin<span class="req">*</span></label>
            <select asp-for="TerminID" class="hz-select" asp-items="ViewBag.TerminID as SelectList"><option value="">— Odaberite —</option></select>
            <span asp-validation-for="TerminID" class="hz-error"></span>
        </div>
        <div class="hz-field">
            <label asp-for="PacijentID" class="hz-label">Pacijent<span class="req">*</span></label>
            <select asp-for="PacijentID" class="hz-select" asp-items="ViewBag.PacijentID as SelectList"><option value="">— Odaberite —</option></select>
            <span asp-validation-for="PacijentID" class="hz-error"></span>
        </div>
        <div class="hz-field hz-full">
            <label asp-for="Dijagnoza" class="hz-label">Dijagnoza<span class="req">*</span></label>
            <input type="text" asp-for="Dijagnoza" placeholder="npr. Akutni bronhitis" class="hz-input" />
            <span asp-validation-for="Dijagnoza" class="hz-error"></span>
        </div>
        <div class="hz-field hz-full">
            <label asp-for="Opis" class="hz-label">Opis nalaza<span class="req">*</span></label>
            <textarea asp-for="Opis" placeholder="Detaljan opis kliničkog nalaza..." class="hz-textarea"></textarea>
            <span asp-validation-for="Opis" class="hz-error"></span>
        </div>
        <div class="hz-field hz-full">
            <label asp-for="Terapija" class="hz-label">Terapija<span class="req">*</span></label>
            <textarea asp-for="Terapija" placeholder="Propisana terapija i preporuke..." class="hz-textarea"></textarea>
            <span asp-validation-for="Terapija" class="hz-error"></span>
        </div>
            </div>

            <div class="hz-actions">
                <a asp-action="Index" class="hz-btn hz-btn-ghost">Odustani</a>
                <button type="submit" class="hz-btn hz-btn-primary">Sačuvaj izmjene</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
