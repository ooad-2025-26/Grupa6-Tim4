@model HealthZone.Models.Recenzija

@{
    ViewData["Title"] = "Detalji recenziju";
}

<link rel="stylesheet" href="~/css/healthzone.css" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

<div class="hz-page hz-page-narrow">
    <a href="javascript:history.back()" class="hz-back">Nazad</a>

    <div class="hz-header">
        <div class="hz-logo">⭐</div>
        <div class="hz-header-main">
            <h1 class="hz-title">Detalji recenziju</h1>
            <p class="hz-subtitle">Pregled svih informacija za odabranu stavku.</p>
        </div>
    </div>

    <div class="hz-card">
        <div class="hz-section-title">Podaci</div>
        <div class="hz-grid">
        <div class="hz-field">
            <label asp-for="PacijentID" class="hz-label">Pacijent<span class="req">*</span></label>
            <div class="hz-input hz-readonly">@Model.PacijentID</div>
            
        </div>
        <div class="hz-field">
            <label asp-for="DoktorID" class="hz-label">Doktor<span class="req">*</span></label>
            <div class="hz-input hz-readonly">@Model.DoktorID</div>
            
        </div>
        <div class="hz-field">
            <label asp-for="OcjenaLjubaznosti" class="hz-label">Ljubaznost (1–5)<span class="req">*</span></label>
            <div class="hz-input hz-readonly">@Model.OcjenaLjubaznosti</div>
            
        </div>
        <div class="hz-field">
            <label asp-for="OcjenaProfesionalnosti" class="hz-label">Profesionalnost (1–5)<span class="req">*</span></label>
            <div class="hz-input hz-readonly">@Model.OcjenaProfesionalnosti</div>
            
        </div>
        <div class="hz-field">
            <label asp-for="OcjenaUsluge" class="hz-label">Usluga (1–5)<span class="req">*</span></label>
            <div class="hz-input hz-readonly">@Model.OcjenaUsluge</div>
            
        </div>
        <div class="hz-field hz-full">
            <label asp-for="Komentar" class="hz-label">Komentar<span class="req">*</span></label>
            <div class="hz-input hz-readonly" style="min-height:60px;white-space:pre-wrap">@Model.Komentar</div>
            
        </div>
        </div>

        <div class="hz-actions hz-actions-between">
            <a asp-action="Index" class="hz-btn hz-btn-ghost">Nazad</a>
            <div style="display:flex;gap:10px">
                <a asp-action="Edit" asp-route-id="@Model.RecenzijaId" class="hz-btn hz-btn-ghost">Uredi</a>
                <a asp-action="Delete" asp-route-id="@Model.RecenzijaId" class="hz-btn hz-btn-danger">Obriši</a>
            </div>
        </div>
    </div>
</div>
