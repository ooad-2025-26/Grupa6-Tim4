@model HealthZone.Models.Notifikacija

@{
    ViewData["Title"] = "Detalji notifikaciju";
}

<link rel="stylesheet" href="~/css/healthzone.css" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

<div class="hz-page hz-page-narrow">
    <a href="javascript:history.back()" class="hz-back">Nazad</a>

    <div class="hz-header">
        <div class="hz-logo">🔔</div>
        <div class="hz-header-main">
            <h1 class="hz-title">Detalji notifikaciju</h1>
            <p class="hz-subtitle">Pregled svih informacija za odabranu stavku.</p>
        </div>
    </div>

    <div class="hz-card">
        <div class="hz-section-title">Podaci</div>
        <div class="hz-grid">
        <div class="hz-field">
            <label asp-for="TerminID" class="hz-label">Termin<span class="req">*</span></label>
            <div class="hz-input hz-readonly">@Model.TerminID</div>
            
        </div>
        <div class="hz-field">
            <label asp-for="status" class="hz-label">Status</label>
            <div class="hz-input hz-readonly">@Model.status</div>
            
        </div>
        <div class="hz-field">
            <label asp-for="DatumSlanja" class="hz-label">Datum slanja<span class="req">*</span></label>
            <div class="hz-input hz-readonly">@Model.DatumSlanja.ToString("dd.MM.yyyy")</div>
            
        </div>
        <div class="hz-field hz-full">
            <label asp-for="Poruka" class="hz-label">Poruka<span class="req">*</span></label>
            <div class="hz-input hz-readonly" style="min-height:60px;white-space:pre-wrap">@Model.Poruka</div>
            
        </div>
        </div>

        <div class="hz-actions hz-actions-between">
            <a asp-action="Index" class="hz-btn hz-btn-ghost">Nazad</a>
            <div style="display:flex;gap:10px">
                <a asp-action="Edit" asp-route-id="@Model.NotifikacijaId" class="hz-btn hz-btn-ghost">Uredi</a>
                <a asp-action="Delete" asp-route-id="@Model.NotifikacijaId" class="hz-btn hz-btn-danger">Obriši</a>
            </div>
        </div>
    </div>
</div>
