@model HealthZone.Models.Korisnik

@{
    ViewData["Title"] = "Obriši — korisnika";
}
@{
    string uloga = ViewBag.Uloga as string ?? "";
}
<link rel="stylesheet" href="~/css/healthzone.css" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

<div class="hz-page hz-page-narrow">
    <a href="javascript:history.back()" class="hz-back">Nazad</a>

    <div class="hz-header">
        <div class="hz-logo">👤</div>
        <div class="hz-header-main">
            <h1 class="hz-title">Obriši korisnika</h1>
            <p class="hz-subtitle">Potvrdite trajno brisanje stavke. Ova akcija se ne može poništiti.</p>
        </div>
    </div>

    @if (ViewBag.GreskaBrisanja != null)
    {
        <div class="hz-warning-panel" style="background:#fcebeb;border-color:#f09595;">
            <div class="ic">🚫</div>
            <div>
                <h4 style="color:#a32d2d;">Brisanje nije moguće</h4>
                <p style="color:#a32d2d;">@ViewBag.GreskaBrisanja</p>
            </div>
        </div>
    }
    else
    {
        <div class="hz-warning-panel">
            <div class="ic">⚠️</div>
            <div>
                <h4>Trajno brisanje</h4>
                <p>Ova stavka će biti uklonjena iz HealthZone sistema. Povezani podaci mogu postati neispravni.</p>
            </div>
        </div>
    }

    <div class="hz-card">
        <div class="hz-section-title">Podaci</div>
        <div class="hz-grid">
            <div class="hz-field">
                <label asp-for="Ime" class="hz-label">Ime<span class="req">*</span></label>
                <div class="hz-input hz-readonly">@Model.Ime</div>

            </div>
            <div class="hz-field">
                <label asp-for="Prezime" class="hz-label">Prezime<span class="req">*</span></label>
                <div class="hz-input hz-readonly">@Model.Prezime</div>

            </div>
            <div class="hz-field">
                <label asp-for="Email" class="hz-label">Email<span class="req">*</span></label>
                <div class="hz-input hz-readonly">@Model.Email</div>

            </div>
            <div class="hz-field">
                <label asp-for="PhoneNumber" class="hz-label">Broj telefona</label>
                <div class="hz-input hz-readonly">@Model.PhoneNumber</div>

            </div>
            @if (uloga == "Pacijent")
            {
                <div class="hz-field">
                    <label asp-for="BrojKartona" class="hz-label">Broj kartona</label>
                    <div class="hz-input hz-readonly">@Model.BrojKartona</div>
                </div>

                <div class="hz-field">
                    <label asp-for="Prioritet" class="hz-label">Prioritet</label>
                    <div class="hz-input hz-readonly">@Model.Prioritet</div>
                </div>
            }

            @if (uloga == "Doktor")
            {
                <div class="hz-field">
                    <label asp-for="Specijalizacija" class="hz-label">Specijalizacija</label>
                    <div class="hz-input hz-readonly">@Model.Specijalizacija</div>
                </div>
            }
            <div class="hz-field">
                <label for="uloga" class="hz-label">Uloga</label>
                <div class="hz-input hz-readonly">@uloga</div>
            </div>
        </div>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="hz-actions hz-actions-between">
                <a asp-action="Index" class="hz-btn hz-btn-ghost">Odustani</a>
                @if (ViewBag.GreskaBrisanja == null)
                {
                    <button type="submit" class="hz-btn hz-btn-danger">Da, obriši trajno</button>
                }
            </div>
        </form>
    </div>
</div>
