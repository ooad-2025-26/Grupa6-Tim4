@model IEnumerable<HealthZone.Models.MedicinskaUsluga>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Naziv)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Vrsta)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Opis)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Cijena)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.Naziv)
            </td>
            <td>
                @Html.DisplayFor(model => item.Vrsta)
            </td>
            <td>
                @Html.DisplayFor(model => item.Opis)
            </td>
            <td>
                @Html.DisplayFor(model => item.Cijena)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.UslugaId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.UslugaId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.UslugaId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
