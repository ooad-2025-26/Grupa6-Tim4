@model HealthZone.Models.ListaCekanja

@{
    ViewData["Title"] = "Detalji liste čekanja";
}

<link rel="stylesheet" href="~/css/healthzone.css" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

<style>
    .hz-badge-spec {
        background: #e1f5ee;
        color: #0f6e56;
    }
</style>

<div class="hz-page hz-page-narrow">
    <a href="javascript:history.back()" class="hz-back">Nazad</a>

    <div class="hz-header">
        <div class="hz-logo">📋</div>
        <div class="hz-header-main">
            <h1 class="hz-title">Detalji liste čekanja</h1>
            <p class="hz-subtitle">Pregled svih informacija za odabranu listu čekanja.</p>
        </div>
    </div>

    <div class="hz-card">
        <div class="hz-section-title">Podaci</div>
        <div class="hz-grid">
            <div class="hz-field">
                <label class="hz-label">ID Liste</label>
                <div class="hz-input hz-readonly" style="font-family:ui-monospace,monospace;color:#185fa5;font-weight:600">#@Model.ListaId</div>
            </div>
            <div class="hz-field">
                <label class="hz-label">Doktor</label>
                <div class="hz-input hz-readonly">@Model.Doktor?.Ime @Model.Doktor?.Prezime</div>
            </div>
            <div class="hz-field">
                <label class="hz-label">Email doktora</label>
                <div class="hz-input hz-readonly">@(Model.Doktor?.Email ?? "—")</div>
            </div>
            <div class="hz-field">
                <label class="hz-label">Specijalizacija</label>
                <div class="hz-input hz-readonly">
                    @if (Model.Doktor?.Specijalizacija != null)
                    {
                        <span class="hz-badge hz-badge-spec">@Model.Doktor.Specijalizacija</span>
                    }
                    else
                    {
                        @:—
                    }
                </div>
            </div>
        </div>

        <div class="hz-actions hz-actions-between">
            <a asp-action="Index" asp-controller="ListaCekanja" class="hz-btn hz-btn-ghost">Nazad</a>
            <div style="display:flex;gap:10px">
                <a asp-action="Edit" asp-controller="ListaCekanja" asp-route-id="@Model.ListaId" class="hz-btn hz-btn-ghost">Uredi</a>
                <a asp-action="Delete" asp-controller="ListaCekanja" asp-route-id="@Model.ListaId" class="hz-btn hz-btn-danger">Obriši</a>
            </div>
        </div>
    </div>
</div>
