@{
    ViewData["Title"] = "Registracija";
}

<style>
    body, html {
        background: #f0f4f8;
        min-height: 100vh;
    }

    .auth-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 16px;
        background: #f0f4f8;
    }

    .auth-container {
        width: 100%;
        max-width: 480px;
    }

    .auth-heading {
        text-align: center;
        margin-bottom: 28px;
    }

        .auth-heading h1 {
            font-size: 28px;
            font-weight: 800;
            color: #111827;
            margin-bottom: 6px;
        }

        .auth-heading p {
            font-size: 15px;
            color: #6b7280;
            margin: 0;
        }

    /* Tab switcher */
    .auth-tabs {
        display: flex;
        background: #e5e9f0;
        border-radius: 14px;
        padding: 5px;
        margin-bottom: 24px;
        gap: 4px;
    }

    .auth-tab {
        flex: 1;
        text-align: center;
        padding: 10px 0;
        border-radius: 10px;
        font-size: 15px;
        font-weight: 600;
        text-decoration: none;
        transition: all .2s;
        color: #6b7280;
        background: transparent;
    }

        .auth-tab.active {
            background: #fff;
            color: #111827;
            box-shadow: 0 1px 4px rgba(0,0,0,0.10);
        }

        .auth-tab:hover:not(.active) {
            color: #374151;
            text-decoration: none;
        }

    /* Card */
    .auth-card {
        background: #fff;
        border-radius: 20px;
        padding: 32px 28px;
        box-shadow: 0 2px 16px rgba(0,0,0,0.07);
    }

    /* Field */
    .auth-field {
        margin-bottom: 20px;
    }

    .auth-label {
        display: block;
        font-size: 14px;
        font-weight: 600;
        color: #111827;
        margin-bottom: 8px;
    }

    .auth-input-wrap {
        position: relative;
        display: flex;
        align-items: center;
    }

    .auth-input-icon {
        position: absolute;
        left: 14px;
        color: #9ca3af;
        font-size: 16px;
        pointer-events: none;
        display: flex;
        align-items: center;
    }

    .auth-input {
        width: 100%;
        padding: 13px 16px 13px 42px;
        border: 1.5px solid #e5e7eb;
        border-radius: 12px;
        font-size: 15px;
        color: #111827;
        background: #fff;
        outline: none;
        transition: border-color .2s;
    }

        .auth-input:focus {
            border-color: #0BA5A4;
            box-shadow: 0 0 0 3px rgba(11,165,164,0.10);
        }

        .auth-input::placeholder {
            color: #9ca3af;
        }

    /* Eye toggle */
    .auth-eye {
        position: absolute;
        right: 14px;
        background: none;
        border: none;
        cursor: pointer;
        color: #9ca3af;
        display: flex;
        align-items: center;
        padding: 4px;
        font-size: 16px;
    }

        .auth-eye:hover {
            color: #374151;
        }

    /* Error alert */
    .auth-alert {
        background: #fef2f2;
        border: 1.5px solid #fca5a5;
        border-radius: 10px;
        color: #b91c1c;
        padding: 11px 14px;
        font-size: 14px;
        margin-bottom: 20px;
    }

    /* Submit */
    .auth-btn {
        width: 100%;
        padding: 14px;
        background: #0BA5A4;
        color: #fff;
        border: none;
        border-radius: 12px;
        font-size: 16px;
        font-weight: 700;
        cursor: pointer;
        transition: background .2s, transform .1s;
        margin-top: 4px;
    }

        .auth-btn:hover {
            background: #099493;
        }

        .auth-btn:active {
            transform: scale(0.98);
        }

    .auth-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0 16px;
    }
</style>

<div class="auth-wrapper">
    <div class="auth-container">

        <div class="auth-heading">
            <h1>Kreirajte nalog</h1>
            <p>Registrujte se za pristup HealthZone sistemu</p>
        </div>

        <div class="auth-tabs">
            <a asp-action="Login" asp-controller="Account" class="auth-tab">Prijava</a>
            <a href="#" class="auth-tab active">Registracija</a>
        </div>

        <div class="auth-card">

            @if (ViewData["Greška"] != null)
            {
                <div class="auth-alert">⚠️ @ViewData["Greška"]</div>
            }

            <form method="post" asp-action="Register" asp-controller="Account">
                @Html.AntiForgeryToken()

                <div class="auth-grid">
                    <div class="auth-field">
                        <label class="auth-label">Ime</label>
                        <div class="auth-input-wrap">
                            <span class="auth-input-icon">
                                <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                                    <circle cx="12" cy="8" r="4" />
                                    <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
                                </svg>
                            </span>
                            <input type="text" name="ime" class="auth-input" placeholder="Vaše ime" required autocomplete="given-name" />
                        </div>
                    </div>

                    <div class="auth-field">
                        <label class="auth-label">Prezime</label>
                        <div class="auth-input-wrap">
                            <span class="auth-input-icon">
                                <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                                    <circle cx="12" cy="8" r="4" />
                                    <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
                                </svg>
                            </span>
                            <input type="text" name="prezime" class="auth-input" placeholder="Vaše prezime" required autocomplete="family-name" />
                        </div>
                    </div>
                </div>

                <div class="auth-field">
                    <label class="auth-label">Email adresa</label>
                    <div class="auth-input-wrap">
                        <span class="auth-input-icon">
                            <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                                <rect x="2" y="4" width="20" height="16" rx="2" />
                                <path d="m2 7 10 7 10-7" />
                            </svg>
                        </span>
                        <input type="email" name="email" class="auth-input" placeholder="vas@email.com" required autocomplete="email" />
                    </div>
                </div>

                <div class="auth-field">
                    <label class="auth-label">Broj telefona</label>
                    <div class="auth-input-wrap">
                        <span class="auth-input-icon">
                            <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.18 2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                            </svg>
                        </span>
                        <input type="tel" name="telefon" class="auth-input" autocomplete="tel" />
                    </div>
                </div>

                <div class="auth-field">
                    <label class="auth-label">Šifra</label>
                    <div class="auth-input-wrap">
                        <span class="auth-input-icon">
                            <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                                <rect x="3" y="11" width="18" height="11" rx="2" />
                                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                            </svg>
                        </span>
                        <input type="password" name="lozinka" id="lozinka-input" class="auth-input" placeholder="••••••••" required autocomplete="new-password" />
                        <button type="button" class="auth-eye" id="toggle-lozinka" title="Prikaži/sakrij šifru">
                            <svg id="eye-icon-1" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                <circle cx="12" cy="12" r="3" />
                            </svg>
                        </button>
                    </div>
                </div>

                <div class="auth-field">
                    <label class="auth-label">Potvrda šifre</label>
                    <div class="auth-input-wrap">
                        <span class="auth-input-icon">
                            <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                                <rect x="3" y="11" width="18" height="11" rx="2" />
                                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                            </svg>
                        </span>
                        <input type="password" name="potvrdiLozinku" id="potvrda-input" class="auth-input" placeholder="••••••••" required autocomplete="new-password" />
                        <button type="button" class="auth-eye" id="toggle-potvrda" title="Prikaži/sakrij šifru">
                            <svg id="eye-icon-2" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                <circle cx="12" cy="12" r="3" />
                            </svg>
                        </button>
                    </div>
                </div>

                <button type="submit" class="auth-btn">Registracija</button>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Helper za toggle lozinke
        function togglePassword(inputId, iconId) {
            var input = document.getElementById(inputId);
            var icon = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/>';
            } else {
                input.type = 'password';
                icon.innerHTML = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
            }
        }

        document.getElementById('toggle-lozinka').addEventListener('click', function () {
            togglePassword('lozinka-input', 'eye-icon-1');
        });

        document.getElementById('toggle-potvrda').addEventListener('click', function () {
            togglePassword('potvrda-input', 'eye-icon-2');
        });
    </script>
}
